  "certifications": [
    {
      "id": "CERT-1",
      "name": "Mechanical Maintenance Level 1",
      "level": 1,
      "scope": "Authorized to perform basic mechanical tasks including routine inspections, minor adjustments, and component replacement under direct supervision."
    },
    {
      "id": "CERT-2",
      "name": "Mechanical Maintenance Level 2",
      "level": 2,
      "scope": "Authorized to perform intermediate mechanical work including pump overhauls, bearing replacement, alignment, and bolt torquing with minimal supervision."
    },
    {
      "id": "CERT-3",
      "name": "Mechanical Maintenance Level 3",
      "level": 3,
      "scope": "Authorized to perform advanced mechanical work, complex troubleshooting, precision alignment, and to supervise and inspect work performed by lower level technicians."
    },
    {
      "id": "CERT-4",
      "name": "Electrical Safety LV Authorization",
      "level": 2,
      "scope": "Authorized to work on low voltage electrical systems up to 1000V AC including motor connections, control circuits, and isolation procedures."
    },
    {
      "id": "CERT-5",
      "name": "Electrical Technician Advanced",
      "level": 3,
      "scope": "Authorized to perform advanced electrical diagnostics, testing, and troubleshooting including insulation resistance testing, thermography, and electrical system modifications."
    },
    {
      "id": "CERT-6",
      "name": "Pressure Systems Inspector Level 2",
      "level": 2,
      "scope": "Authorized to inspect, test, and certify pressure vessels, piping systems, and relief devices in accordance with applicable codes and standards."
    },
    {
      "id": "CERT-7",
      "name": "Pressure Systems Technician Level 3",
      "level": 3,
      "scope": "Authorized to design repairs, perform pressure testing, witness hydrostatic tests, and approve pressure system modifications as competent person."
    },
    {
      "id": "CERT-8",
      "name": "Instrumentation Technician Level 2",
      "level": 2,
      "scope": "Authorized to calibrate, maintain, and troubleshoot process instrumentation including transmitters, control valves, analyzers, and safety instrumented systems."
    },
    {
      "id": "CERT-9",
      "name": "Confined Space Entry Authorized",
      "level": 2,
      "scope": "Authorized to enter and work in confined spaces including vessels, tanks, and pits after proper atmospheric testing, ventilation, and permit procedures."
    },
    {
      "id": "CERT-10",
      "name": "Lifting Operations Supervisor",
      "level": 3,
      "scope": "Authorized to plan, supervise, and certify lifting operations including crane lifts, rigging inspections, load calculations, and lift plan approval."
    }
  ],
  "defects": [
    {
      "id": "D-001",
      "name": "Improper Bolt Torque Sequence",
      "severity": "medium",
      "escalation": "supervisor sign-off and re-torque verification required"
    },
    {
      "id": "D-002",
      "name": "Seal Face Misalignment",
      "severity": "high",
      "escalation": "mechanical level 3 technician inspection and realignment"
    },
    {
      "id": "D-003",
      "name": "Cable Insulation Damage",
      "severity": "critical",
      "escalation": "stop work, isolate circuit, notify electrical supervisor and safety officer"
    },
    {
      "id": "D-004",
      "name": "Gasket Surface Scoring",
      "severity": "medium",
      "escalation": "supervisor review, resurface or replace flange as needed"
    },
    {
      "id": "D-005",
      "name": "Bearing Contamination",
      "severity": "medium",
      "escalation": "replace bearing, supervisor to review lubrication procedures"
    },
    {
      "id": "D-006",
      "name": "Valve Packing Leak",
      "severity": "low",
      "escalation": "adjust or replace packing, supervisor notification if persistent"
    },
    {
      "id": "D-007",
      "name": "Motor Winding Insulation Breakdown",
      "severity": "critical",
      "escalation": "stop work, de-energize, electrical level 3 inspection and engineering review"
    },
    {
      "id": "D-008",
      "name": "Pressure Vessel Weld Crack",
      "severity": "critical",
      "escalation": "stop work, isolate system, pressure systems inspector and engineering review required"
    },
    {
      "id": "D-009",
      "name": "Coupling Misalignment Excessive",
      "severity": "high",
      "escalation": "mechanical level 2 or 3 technician to perform precision alignment"
    },
    {
      "id": "D-010",
      "name": "Fastener Thread Damage",
      "severity": "medium",
      "escalation": "replace fastener, supervisor sign-off on critical applications"
    },
    {
      "id": "D-011",
      "name": "Instrument Calibration Drift Beyond Tolerance",
      "severity": "medium",
      "escalation": "recalibrate immediately, notify instrumentation supervisor if repeated"
    },
    {
      "id": "D-012",
      "name": "Pump Impeller Cavitation Damage",
      "severity": "high",
      "escalation": "QA inspector review, engineering analysis of system conditions required"
    },
    {
      "id": "D-013",
      "name": "Inadequate Thread Engagement",
      "severity": "high",
      "escalation": "replace with correct length fastener, mechanical level 3 verification"
    },
    {
      "id": "D-014",
      "name": "Heat Exchanger Tube Fouling Severe",
      "severity": "medium",
      "escalation": "chemical cleaning or tube bundle replacement, supervisor approval required"
    },
    {
      "id": "D-015",
      "name": "Safety Device Bypass or Override Detected",
      "severity": "critical",
      "escalation": "stop work immediately, notify safety officer, management review and investigation"
    }
  ]
